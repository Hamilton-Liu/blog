---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">&#38745;&#24577;&#29983;&#25104; / GitHub Pages / Markdown</p>
				<h1>&#20010;&#20154;&#21338;&#23458;</h1>
				<p>
					&#36825;&#37324;&#29992;&#26469;&#35760;&#24405;&#25216;&#26415;&#23454;&#36341;&#12289;&#35835;&#20070;&#31508;&#35760;&#21644;&#38271;&#26399;&#24605;&#32771;&#12290;&#31449;&#28857;&#22312;&#25552;&#20132;&#21518;&#30001; GitHub Actions
					&#33258;&#21160;&#26500;&#24314;&#65292;&#36755;&#20986;&#20026;&#38745;&#24577;&#25991;&#20214;&#65292;&#35775;&#38382;&#24555;&#12289;&#25104;&#26412;&#20302;&#12289;&#32500;&#25252;&#31616;&#21333;&#12290;
				</p>
				<div class="actions">
					<a class="button" href={`${base}notes/`}>&#38405;&#35835;&#31508;&#35760;</a>
					<a href={`${base}about/`}>&#20102;&#35299;&#25105;</a>
				</div>
			</section>
			<section>
				<h2>&#20889;&#20316;&#26041;&#24335;</h2>
				<p>
					&#26032;&#31508;&#35760;&#25918;&#21040; <code>src/content/notes/</code>
					&#30446;&#24405;&#65292;&#20351;&#29992; Markdown &#25110; MDX&#12290;&#26412;&#22320;&#39044;&#35272;&#29992;
					<code>npm.cmd run dev</code>&#65292;&#21457;&#24067;&#26102;&#30452;&#25509; commit &#24182; push&#12290;
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: 3rem 0 2rem;
	}
	.eyebrow {
		margin: 0 0 0.75rem;
		color: rgb(var(--gray));
		font-size: 0.9rem;
		font-weight: 700;
		letter-spacing: 0;
	}
	.actions {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-top: 1.5rem;
	}
	.button {
		display: inline-flex;
		align-items: center;
		min-height: 2.5rem;
		padding: 0 1rem;
		border-radius: 6px;
		background: rgb(var(--black));
		color: white;
		text-decoration: none;
	}
	.button:hover {
		color: white;
		background: rgb(var(--gray-dark));
	}
	@media (max-width: 720px) {
		.actions {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>
