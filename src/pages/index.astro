---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">静态生成 / GitHub Pages / Markdown</p>
				<h1>个人博客</h1>
				<p>
					这里用来记录技术实践、读书笔记和长期思考。站点在提交后由 GitHub Actions
					自动构建，输出为静态文件，访问快、成本低、维护简单。
				</p>
				<div class="actions">
					<a class="button" href={`${base}notes/`}>阅读笔记</a>
					<a href={`${base}about/`}>了解我</a>
				</div>
			</section>
			<section>
				<h2>写作方式</h2>
				<p>
					新笔记放到 <code>src/content/notes/</code>
					目录，使用 Markdown 或 MDX。本地预览用
					<code>npm.cmd run dev</code>，发布时直接 commit 并 push。
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: 3rem 0 2rem;
	}
	.eyebrow {
		margin: 0 0 0.75rem;
		color: rgb(var(--gray));
		font-size: 0.9rem;
		font-weight: 700;
		letter-spacing: 0;
	}
	.actions {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-top: 1.5rem;
	}
	.button {
		display: inline-flex;
		align-items: center;
		min-height: 2.5rem;
		padding: 0 1rem;
		border-radius: 6px;
		background: rgb(var(--black));
		color: white;
		text-decoration: none;
	}
	.button:hover {
		color: white;
		background: rgb(var(--gray-dark));
	}
	@media (max-width: 720px) {
		.actions {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>
