---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const notes = (await getCollection('notes')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const categories = [
	{ id: 'all', label: '&#20840;&#37096;' },
	{ id: 'thoughts', label: '&#38543;&#24819;' },
	{ id: 'tech', label: '&#25216;&#26415;' },
	{ id: 'talk', label: '&#28459;&#35848;' },
];
const categoryLabels = {
	thoughts: '&#38543;&#24819;',
	tech: '&#25216;&#26415;',
	talk: '&#28459;&#35848;',
};
const base = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
const formatMonthValue = (date: Date) =>
	`${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`;
const formatMonthLabel = (value: string) => {
	const [year, month] = value.split('-');
	return `${year}.${month}`;
};
const months = [...new Set(notes.map((note) => formatMonthValue(note.data.pubDate)))];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`笔记 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-head">
				<h1>&#31508;&#35760;</h1>
				<p>&#35760;&#24405;&#25216;&#26415;&#23454;&#36341;&#12289;&#26085;&#24120;&#38543;&#24819;&#21644;&#38271;&#26399;&#35266;&#23519;&#12290;</p>
			</header>

			<nav class="tabs" aria-label="Note categories">
				{
					categories.map((category) => (
						<button
							class:list={['tab', { active: category.id === 'all' }]}
							type="button"
							data-category={category.id}
							set:html={category.label}
						/>
					))
				}
			</nav>

			<div class="notes-layout">
				<section class="note-list" aria-live="polite">
					{
						notes.map((note) => {
							const month = formatMonthValue(note.data.pubDate);
							return (
								<article class="note-card" data-category={note.data.category} data-month={month}>
									<a href={`${base}notes/${note.id}/`}>
										<div class="note-meta">
											<span set:html={categoryLabels[note.data.category]} />
											<span>
												<FormattedDate date={note.data.pubDate} />
											</span>
										</div>
										<h2>{note.data.title}</h2>
										<p>{note.data.description}</p>
									</a>
								</article>
							);
						})
					}
					<p class="empty" hidden>&#24403;&#21069;&#26465;&#20214;&#19979;&#27809;&#26377;&#31508;&#35760;&#12290;</p>
				</section>

				<aside class="timeline" aria-label="Timeline">
					<h2>&#26102;&#20809;&#36724;</h2>
					<button class="time-link active" type="button" data-month="all">&#20840;&#37096;&#26102;&#38388;</button>
					{
						months.map((month) => (
							<button class="time-link" type="button" data-month={month}>
								{formatMonthLabel(month)}
							</button>
						))
					}
				</aside>
			</div>
		</main>
		<Footer />
		<script>
			const tabs = document.querySelectorAll('[data-category]');
			const timeLinks = document.querySelectorAll('[data-month]');
			const cards = document.querySelectorAll('.note-card');
			const empty = document.querySelector('.empty');
			let activeCategory = 'all';
			let activeMonth = 'all';

			function update() {
				let visibleCount = 0;
				cards.forEach((card) => {
					const matchesCategory =
						activeCategory === 'all' || card.dataset.category === activeCategory;
					const matchesMonth = activeMonth === 'all' || card.dataset.month === activeMonth;
					const visible = matchesCategory && matchesMonth;
					card.toggleAttribute('hidden', !visible);
					if (visible) visibleCount += 1;
				});
				if (empty) empty.toggleAttribute('hidden', visibleCount > 0);
			}

			tabs.forEach((tab) => {
				tab.addEventListener('click', () => {
					activeCategory = tab.dataset.category;
					tabs.forEach((item) => item.classList.toggle('active', item === tab));
					update();
				});
			});
			timeLinks.forEach((link) => {
				link.addEventListener('click', () => {
					activeMonth = link.dataset.month;
					timeLinks.forEach((item) => item.classList.toggle('active', item === link));
					update();
				});
			});
		</script>
	</body>
</html>

<style>
	main {
		width: 960px;
	}
	.page-head {
		margin-bottom: 1.5rem;
	}
	.tabs {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 2rem;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.tab {
		padding: 0.65rem 0.85rem;
		border: 0;
		border-bottom: 3px solid transparent;
		background: transparent;
		color: rgb(var(--gray-dark));
		cursor: pointer;
		font: inherit;
	}
	.tab.active {
		border-bottom-color: var(--accent);
		color: rgb(var(--black));
		font-weight: 700;
	}
	.notes-layout {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 180px;
		gap: 2.5rem;
		align-items: start;
	}
	.note-list {
		display: grid;
		gap: 1rem;
	}
	.note-card {
		border-bottom: 1px solid rgb(var(--gray-light));
		padding-bottom: 1rem;
	}
	.note-card a {
		display: block;
		color: inherit;
		text-decoration: none;
	}
	.note-card h2 {
		margin: 0.25rem 0;
		font-size: 1.25rem;
	}
	.note-card p {
		margin: 0;
		color: rgb(var(--gray));
	}
	.note-card a:hover h2 {
		color: var(--accent);
	}
	.note-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		color: rgb(var(--gray));
		font-size: 0.9rem;
	}
	.timeline {
		position: sticky;
		top: 1rem;
		border-left: 2px solid rgb(var(--gray-light));
		padding-left: 1rem;
	}
	.timeline h2 {
		font-size: 1rem;
	}
	.time-link {
		display: block;
		width: 100%;
		padding: 0.35rem 0;
		border: 0;
		background: transparent;
		color: rgb(var(--gray));
		cursor: pointer;
		font: inherit;
		text-align: left;
	}
	.time-link.active {
		color: rgb(var(--black));
		font-weight: 700;
	}
	.empty {
		color: rgb(var(--gray));
	}
	@media (max-width: 720px) {
		.notes-layout {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}
		.timeline {
			position: static;
			border-left: 0;
			border-top: 1px solid rgb(var(--gray-light));
			padding: 1rem 0 0;
		}
	}
</style>
